# Copy to .env and fill in real values. Never commit .env.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Memory (optional for local dev — falls back to in-memory) ---
DATABASE_URL=postgresql://party:party@localhost:5432/party_agent
REDIS_URL=redis://localhost:6379/0

# --- External APIs ---
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
# Free key at https://developer.ticketmaster.com/ — US/UK/EU/AU events
TICKETMASTER_API_KEY=
# Free at https://predicthq.com/signup — 200+ countries, Japan/Sri Lanka/Africa/Asia/Middle East
PREDICTHQ_TOKEN=
# SerpAPI — venue-site auto-discovery for the worldwide crawl fallback.
# Free tier: 100 searches/mo at https://serpapi.com/
SERPAPI_API_KEY=

# --- Web crawl fallback (off-platform events: Sri Lanka, smaller markets) ---
CRAWL_FRESHNESS_HOURS=6
CRAWL_MAX_SITES_PER_CITY=8
CRAWL_EXTRACTOR_MODEL=claude-haiku-4-5

# Always-on scheduler — runs inside the FastAPI process. Disable when running
# multiple replicas and only one should crawl.
CRAWL_SCHEDULER_ENABLED=true
CRAWL_REFRESH_INTERVAL_MINUTES=60
CRAWL_CLEANUP_INTERVAL_MINUTES=60
# Events are deleted this many hours AFTER their event_date passes.
CRAWL_EVENT_TTL_HOURS=6

# --- LangSmith tracing (optional but recommended in dev) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=party-chat-agent

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
