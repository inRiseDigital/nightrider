rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true when the authenticated user has isOrganizer:true in their profile.
    function isOrganizer() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isOrganizer', false) == true;
    }

    // ── Events ────────────────────────────────────────────────────────────────
    // Public read for event discovery.
    // Backend service account writes bypass rules (admin SDK).
    // Verified organizers can manage their own events from the client.
    match /events/{eventId} {
      allow read: if true;
      allow create: if isOrganizer()
        && request.resource.data.organizerUid == request.auth.uid;
      allow update: if isOrganizer()
        && resource.data.organizerUid == request.auth.uid;
      allow delete: if isOrganizer()
        && resource.data.organizerUid == request.auth.uid;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Each user can only read and write their own document.
    // The rank field can only be incremented, never set to an arbitrary value,
    // enforced by ensuring any rank change is positive and within a sane limit.
    // Delete is allowed so users can permanently delete their own accounts.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        // Prevent direct rank manipulation: if rank is being changed, it must
        // only increase by at most 50 points in a single write.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['rank'])
            || (request.resource.data.rank is int
                && request.resource.data.rank >= resource.data.rank
                && request.resource.data.rank <= resource.data.rank + 50));
      // Users may delete their own account document (account deletion flow).
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Favourites subcollection — owner only
      match /favourites/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Privacy / notification settings — owner only
      match /settings/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Chat history — owner reads; writes require a verified email so the AI
      // chat (which persists sessions here) is gated to verified users only.
      match /chat_sessions/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid
          && request.auth.token.email_verified == true;
      }
    }

    // ── Avatars ───────────────────────────────────────────────────────────────
    match /avatars/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Live Hub — Clubs ──────────────────────────────────────────────────────
    // Read requires auth. Writes go through backend only.
    match /live_hub_clubs/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Live Hub — Reports ────────────────────────────────────────────────────
    // Auth users can submit reports and upvote once per report.
    // An upvote is the only allowed update (only 'upvotes' field changes by +1).
    match /live_hub_reports/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 500
        && request.resource.data.username is string
        && request.resource.data.username.size() <= 64;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
        && request.resource.data.upvotes == resource.data.upvotes + 1;
      allow delete: if false;
    }

    // ── Live Hub — Social Events ──────────────────────────────────────────────
    match /live_hub_social/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Deny everything else by default ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
