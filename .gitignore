*.dart_tool/
.dart_tool/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.iml

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

